#!/bin/bash

set -euox pipefail

readonly SCRIPT_NAME="verify-shell-config"
readonly LOG_PREFIX="[chezmoi/${SCRIPT_NAME}]"

log_info() {
  echo "${LOG_PREFIX} INFO: $*" >&2
}

log_warn() {
  echo "${LOG_PREFIX} WARN: $*" >&2
}

log_info "Verifying shell configuration..."

VALIDATION_FAILED=0

# Check Fish config if Fish is installed
if command -v fish &> /dev/null; then
  readonly FISH_CONFIG="${HOME}/.config/fish"

  if [[ -d "$FISH_CONFIG" ]]; then
    log_info "✓ Fish config directory exists"

    if [[ -f "${FISH_CONFIG}/config.fish" ]]; then
      log_info "config.fish found"
    else
      log_warn "config.fish not found"
      VALIDATION_FAILED=1
    fi

    # Check if functions directory exists
    if [[ ! -d "${FISH_CONFIG}/functions" ]]; then
      log_info "Creating Fish functions directory..."
      mkdir -p "${FISH_CONFIG}/functions"
    else
      log_info "Fish functions directory exists"
    fi
  else
    log_warn "✗ Fish config directory not found"
    VALIDATION_FAILED=1
  fi
fi

# Check Bash config (root shell, always exists)
if [[ ! -f "$HOME/.bashrc" ]]; then
  log_warn "~/.bashrc not found (might be expected)"
fi

if [[ $VALIDATION_FAILED -eq 0 ]]; then
  log_info "Shell configuration validation passed"
else
  log_warn "Shell configuration validation completed with warnings (non-fatal)"
fi
