#!/bin/bash

set -euox pipefail

readonly SCRIPT_NAME="cleanup-stale-links"
readonly LOG_PREFIX="[chezmoi/${SCRIPT_NAME}]"

log_info() {
  echo "${LOG_PREFIX} INFO: $*" >&2
}

log_warn() {
  echo "${LOG_PREFIX} WARN: $*" >&2
}

log_info "Cleaning up stale symlinks..."

STALE_COUNT=0

# Function to find and remove broken symlinks
cleanup_stale_in_dir() {
  local dir="$1"

  if [[ ! -d "$dir" ]]; then
    return
  fi

  while IFS= read -r -d '' link; do
    if [[ -L "$link" ]] && [[ ! -e "$link" ]]; then
      log_info "Removing stale symlink: $link"
      rm -f "$link"
      ((STALE_COUNT++))
    fi
  done < <(find "$dir" -maxdepth 3 -type l -print0 2>/dev/null || true)
}

# Check common config directories
readonly CONFIG_DIRS=("$HOME/.config" "$HOME/.local/share")
for dir in "${CONFIG_DIRS[@]}"; do
  if [[ -d "$dir" ]]; then
    cleanup_stale_in_dir "$dir"
  fi
done

if [[ $STALE_COUNT -gt 0 ]]; then
  log_info "Removed $STALE_COUNT stale symlinks"
else
  log_info "No stale symlinks found"
fi
