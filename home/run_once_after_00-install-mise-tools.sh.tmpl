#!/bin/bash

set -euox pipefail

readonly SCRIPT_NAME="install-mise-tools"
readonly LOG_PREFIX="[chezmoi/${SCRIPT_NAME}]"

log_info() {
  echo "${LOG_PREFIX} INFO: $*" >&2
}

log_error() {
  echo "${LOG_PREFIX} ERROR: $*" >&2
}

# Check if mise is installed
if ! command -v mise &> /dev/null; then
  log_info "mise not found in PATH, skipping mise tool installation"
  exit 0
fi

log_info "Installing tools from mise configuration..."

# Verify mise config exists
if [[ ! -f "$HOME/.mise.toml" ]] && [[ ! -f "$HOME/.tool-versions" ]]; then
  log_info "No mise configuration found, skipping installation"
  exit 0
fi

# Install tools
if mise install -y; then
  log_info "Tools installed successfully"
else
  log_error "Failed to install mise tools"
  exit 1
fi
