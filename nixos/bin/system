#!/usr/bin/env bash
set -euo pipefail

HOST="gandalf"
DOTFILES_DIR="$HOME/.dotfiles"

usage() {
  cat <<EOF
Usage: nixhost <command> [args]

Manage the NixOS configuration.

Commands:
    switch [args]     Build and activate new configuration
    build [args]      Build but don't activate (dry run)
    test [args]       Build and activate, with rollback on failure
    rollback          Switch to previous generation
    update            Update flake inputs
    clean             Clean nix store
    generations       Show current generations
    edit [args]       Edit configuration (opens \$EDITOR)
    help              Show this help

Examples:
    nixhost switch
    nixhost build -v
    nixhost rollback
EOF
}

case "${1:-help}" in
switch)
  shift
  cd "$DOTFILES_DIR" && sudo nixos-rebuild --flake '.#'"$HOST" switch "$@"
  ;;
build)
  shift
  cd "$DOTFILES_DIR" && sudo nixos-rebuild --flake '.#'"$HOST" build "$@"
  ;;
test)
  shift
  cd "$DOTFILES_DIR" && sudo nixos-rebuild --flake '.#'"$HOST" test "$@"
  ;;
rollback)
  sudo /run/current-system/bin/switch-to-configuration switch
  ;;
update)
  cd "$DOTFILES_DIR" && nix flake update
  ;;
clean)
  sudo nix-collect-garbage -d
  ;;
generations)
  nix-env -p /nix/var/nix/profiles/system --list-generations
  ;;
edit)
  shift
  "${EDITOR:-nvim}" "$DOTFILES_DIR/nixos/configuration.nix" "$@"
  ;;
cd)
  cd "$DOTFILES_DIR"
  ;;
help | --help | -h)
  usage
  ;;
*)
  echo "Unknown command: $1"
  usage
  exit 1
  ;;
esac
